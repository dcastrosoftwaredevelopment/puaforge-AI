# Server
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=puaforge
DB_PASSWORD=puaforge
DB_NAME=puaforge

# Auth
JWT_SECRET=change-me-in-production

# Google OAuth (get from console.cloud.google.com)
# Used by both server (token verification) and frontend (OAuth button)
GOOGLE_CLIENT_ID=

# PocketBase (image storage)
# Run `npm run pb:setup` once after first docker-compose up to create the collection
POCKETBASE_URL=http://localhost:8090
# Em produção, coloque o endereço público do PocketBase (ex: https://pb.seudominio.com)
POCKETBASE_PUBLIC_URL=http://localhost:8090
PB_ADMIN_EMAIL=admin@puaforge.local
PB_ADMIN_PASSWORD=change-me-in-production

# Publishing — subdomain and custom domain support
# APP_DOMAIN: your app's own domain. Used to:
#   1. Route {slug}.APP_DOMAIN requests to published sites (requires wildcard DNS *.APP_DOMAIN → server IP)
#   2. Show the subdomain URL to users in the publish panel
# Also set APP_DOMAIN in the Vite build env so the frontend can render the URL.
APP_DOMAIN=seuapp.com
# SERVER_IP: the public IP of this server, shown to users when configuring custom DNS records
SERVER_IP=
SUPERUSER_EMAILS=
GA_MEASUREMENT_ID=

# SMTP (email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
APP_URL=https://seuapp.com